//
// databases.cfg.example — SourceMod MySQL configuration example
//
// THIS FILE IS NEVER LOADED AT RUNTIME.
// The real databases.cfg is auto-generated by entrypoint.sh from
// the MM_DB_* environment variables injected by the Python matchmaker.
//
// Copy this file to databases.cfg and replace the placeholder values
// if you are running the match server outside of Docker (e.g., for
// local development or testing).
//
// Both "csgo_matchmaking" and "levels_ranks" point to the same database
// so that the MM plugin and the Levels Ranks plugin share one backend.
//

"Databases"
{
    // Default driver selection — do not remove.
    "default"
    {
        "driver"    "default"
    }

    // -----------------------------------------------------------------------
    // Primary matchmaking database.
    // Used by: csgo_mm_match.sp
    // -----------------------------------------------------------------------
    "csgo_matchmaking"
    {
        "driver"    "mysql"
        "host"      "MM_DB_HOST"        // e.g. 172.17.0.1 (Docker host gateway)
        "database"  "MM_DB_NAME"        // e.g. csgo_matchmaking
        "user"      "MM_DB_USER"        // e.g. csgo_mm
        "pass"      "MM_DB_PASS"        // replace with your actual password
        "port"      "3306"
    }

    // -----------------------------------------------------------------------
    // Levels Ranks plugin connection.
    // Points to the same database — lvl_base and mm_ tables coexist.
    // Used by: levels_ranks plugin (third-party)
    // -----------------------------------------------------------------------
    "levels_ranks"
    {
        "driver"    "mysql"
        "host"      "MM_DB_HOST"        // same host as csgo_matchmaking
        "database"  "MM_DB_NAME"        // same database
        "user"      "MM_DB_USER"
        "pass"      "MM_DB_PASS"
        "port"      "3306"
    }
}
